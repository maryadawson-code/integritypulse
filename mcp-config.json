          "x-api-key": "YOUR_API_KEY"
        }
      }
    }
  },

  "windsurf": {
    "_file": "~/.codeium/windsurf/mcp_config.json",
    "mcpServers": {
      "openclaw-finops": {
        "type": "streamable-http",
